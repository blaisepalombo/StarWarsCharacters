  },
  "components": {
    "schemas": {
      "CharacterInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Luke Skywalker"
          },
          "species": {
            "type": "string",
            "example": "Human"
          },
          "homeworld": {
            "type": "string",
            "example": "Tatooine"
          },
          "affiliation": {
            "type": "string",
            "example": "Jedi Order"
          },
          "collection": {
            "type": "string",
            "example": "Jedi"
          }
        },
        "required": ["name", "species", "affiliation", "collection"]
      },
      "PlanetInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Tatooine"
          },
          "climate": {
            "type": "string",
            "example": "Arid"
          },
          "terrain": {
            "type": "string",
            "example": "Desert"
          },
          "population": {
            "type": "string",
            "example": "200000"
          }
        },
        "required": ["name", "climate", "terrain", "population"]
      },
      "StarshipInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Millennium Falcon"
          },
          "model": {
            "type": "string",
            "example": "YT-1300 light freighter"
          },
          "manufacturer": {
            "type": "string",
            "example": "Corellian Engineering Corporation"
          },
          "crew": {
            "type": "string",
            "example": "4"
          }
        },
        "required": ["name", "model", "manufacturer", "crew"]
      },
      "FactionInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Rebel Alliance"
          },
          "leader": {
            "type": "string",
            "example": "Mon Mothma"
          },
          "alignment": {
            "type": "string",
            "example": "Light Side"
          },
          "headquarters": {
            "type": "string",
            "example": "Yavin 4"
          }
        },
        "required": ["name", "leader", "alignment", "headquarters"]
      }
    }
  }
}